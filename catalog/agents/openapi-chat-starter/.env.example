# Point at any OpenAPI 3.x / Swagger 2.0 document. Defaults to Petstore.
OPENAPI_SPEC_URL=https://petstore3.swagger.io/api/v3/openapi.json

# Optional: override the server base URL from the spec.
# OPENAPI_BASE_URL=https://petstore3.swagger.io/api/v3

# Optional: Bearer token for private APIs.
# OPENAPI_TOKEN=replace-me

# Optional: description shown to the model for this connection.
# OPENAPI_DESCRIPTION=My internal ops API.

# Model access follows your eve setup (Vercel AI Gateway or a provider key).
