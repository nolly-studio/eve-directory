# The feed to digest (RSS or Atom). Defaults to Hacker News front page.
DIGEST_FEED_URL=https://hnrss.org/frontpage

# Slack channel id to post the digest into (right-click channel → copy link;
# the id starts with C).
SLACK_DIGEST_CHANNEL_ID=C0123456789

# Slack credentials are managed by Vercel Connect:
#   vercel link
#   vercel connect create slack --triggers
#   vercel env pull
# Then update the Connect UID in agent/channels/slack.ts.

# Model access follows your eve setup (Vercel AI Gateway or a provider key).
