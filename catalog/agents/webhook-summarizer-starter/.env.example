# Slack channel that receives classified summaries (id starts with C).
SLACK_SUMMARY_CHANNEL_ID=C0123456789

# Optional shared secret. When set, require Authorization: Bearer <secret>.
# WEBHOOK_SECRET=replace-me

# Slack credentials are managed by Vercel Connect:
#   vercel link
#   vercel connect create slack --triggers
#   vercel env pull
# Then update the Connect UID in agent/channels/slack.ts.

# Model access follows your eve setup (Vercel AI Gateway or a provider key).
