# The URL to monitor. Defaults to https://example.com.
UPTIME_WATCH_URL=https://example.com

# Telegram chat id that should receive alerts (DM the bot, then look up
# your chat id, or use a group chat id).
TELEGRAM_ALERT_CHAT_ID=replace-me

# Telegram bot credentials (create a bot with @BotFather).
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace-me

# Model access follows your eve setup (Vercel AI Gateway or a provider key).
