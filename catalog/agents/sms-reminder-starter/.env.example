# Twilio account + Auth Token (Console → Account → API keys & tokens).
TWILIO_ACCOUNT_SID=ACreplace-me
TWILIO_AUTH_TOKEN=replace-me

# Your Twilio phone number in E.164 (outbound SMS sender).
TWILIO_FROM_NUMBER=+15557654321

# Who may text the agent. Comma-separated E.164 numbers, or "*" for demos only.
TWILIO_ALLOW_FROM=+15551234567

# Model access follows your eve setup (Vercel AI Gateway or a provider key).
