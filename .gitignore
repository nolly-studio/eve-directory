# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# fumadocs-mdx generated collections
.source

# production
/build

# misc
.DS_Store
*.pem

# editor / local tooling (do not publish)
.cursor/
.pnpm-store/

# private product/ops notes (kept locally; not published)
/docs/plans/
/docs/release.md
/docs/agents/skills-config.md

# shadcn registry source (generated by scripts/build-registry.mjs; public/r is committed)
/.registry/

# eve build artifacts inside catalog agent apps
catalog/agents/*/node_modules/
catalog/agents/*/.eve/
catalog/agents/*/.output/
catalog/agents/*/.cache/
catalog/agents/*/var/
catalog/agents/*/package-lock.json

# eve build artifacts inside catalog extension packages and test consumers
catalog/extensions/*/*/node_modules/
catalog/extensions/*/*/dist/
catalog/extensions/*/*/.eve/
catalog/extensions/*/*/.output/
catalog/extensions/*/*/.cache/
catalog/extensions/*/*/var/
catalog/extensions/*/*/package-lock.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts
