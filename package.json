{
  "name": "eve-directory",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nolly-studio/eve-directory.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "typecheck": "fumadocs-mdx && tsc --noEmit",
    "scrape:integrations": "node scripts/scrape-integrations.mjs",
    "catalog:validate": "node scripts/validate-catalog.mjs",
    "agents:check": "node scripts/check-agents.mjs",
    "agents:eval": "node scripts/run-agent-evals.mjs",
    "agents:clean": "git clean -Xdf catalog/agents",
    "registry:build": "node scripts/build-registry.mjs && shadcn build .registry/registry.json --output public/r",
    "registry:smoke": "node scripts/registry-smoke.mjs",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "geist": "^1.7.2",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jszip": "^3.4.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "ultracite": "7.9.4"
  }
}
